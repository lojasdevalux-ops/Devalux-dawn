{% comment %}
  Favorites (wishlist) page. Products are stored client-side (localStorage) and
  rendered by assets/favorites.js into #FavoritesGrid.
{% endcomment %}

<div class="page-width epoca-favorites section-{{ section.id }}-padding">
  <h1 class="epoca-favorites__heading">{{ section.settings.heading | default: 'Meus favoritos' }}</h1>

  <p id="FavoritesEmpty" class="epoca-favorites__empty">
    {{ section.settings.empty_text | default: 'Você ainda não adicionou nenhum produto aos favoritos. Toque no coração dos produtos para salvá-los aqui.' }}
  </p>

  <div id="FavoritesGrid" class="epoca-favorites__grid"></div>
</div>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  .epoca-favorites__heading {
    margin: 0 0 2.4rem;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{% schema %}
{
  "name": "Favoritos",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Meus favoritos"
    },
    {
      "type": "text",
      "id": "empty_text",
      "label": "Texto quando vazio",
      "default": "Você ainda não adicionou nenhum produto aos favoritos."
    },
    {
      "type": "header",
      "content": "Espaçamento"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Espaço acima",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Espaço abaixo",
      "default": 52
    }
  ],
  "presets": [
    {
      "name": "Favoritos"
    }
  ]
}
{% endschema %}
