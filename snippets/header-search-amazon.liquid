{% comment %}
  Renders an Amazon-style persistent search bar for the header.

  - A text input with Shopify predictive search (autocomplete).
  - An orange search button on the right.

  Keeps the markup the predictive-search / search-form web components expect
  (input[type="search"][name="q"], button[type="reset"], [data-predictive-search]).

  Accepts:
  - input_id: {String} Unique id for the search input element (required)

  Usage:
  {% render 'header-search-amazon', input_id: 'Search-Amazon' %}
{% endcomment %}

{%- if settings.predictive_search_enabled -%}
  <predictive-search class="amazon-search" data-loading-text="{{ 'accessibility.loading' | t }}">
{%- else -%}
  <search-form class="amazon-search">
{%- endif -%}
  <form action="{{ routes.search_url }}" method="get" role="search" class="amazon-search__form">
    <div class="amazon-search__field">
      <input
        class="amazon-search__input"
        id="{{ input_id }}"
        type="search"
        name="q"
        value="{{ search.terms | escape }}"
        placeholder="{{ 'general.search.search' | t }}"
        {%- if settings.predictive_search_enabled -%}
          role="combobox"
          aria-expanded="false"
          aria-owns="predictive-search-results"
          aria-controls="predictive-search-results"
          aria-haspopup="listbox"
          aria-autocomplete="list"
          autocorrect="off"
          autocomplete="off"
          autocapitalize="off"
          spellcheck="false"
        {%- endif -%}
      >
      <label class="visually-hidden" for="{{ input_id }}">{{ 'general.search.search' | t }}</label>
      <input type="hidden" name="options[prefix]" value="last">
      <button
        type="reset"
        class="amazon-search__reset{% if search.terms == blank %} hidden{% endif %}"
        aria-label="{{ 'general.search.reset' | t }}"
      >
        <span class="svg-wrapper">
          {{- 'icon-close-small.svg' | inline_asset_content -}}
        </span>
      </button>
    </div>

    <button type="submit" class="amazon-search__submit" aria-label="{{ 'general.search.search' | t }}">
      <span class="svg-wrapper">
        {{- 'icon-search.svg' | inline_asset_content -}}
      </span>
    </button>
  </form>

  {%- comment -%}
    The results dropdown lives outside the form so the form's overflow:hidden
    (used to clip the rounded corners) does not hide it. It stays inside the
    <predictive-search> element, which is what predictive-search.js queries.
  {%- endcomment -%}
  {%- if settings.predictive_search_enabled -%}
    <div class="predictive-search predictive-search--header" tabindex="-1" data-predictive-search>
      {%- render 'loading-spinner', class: 'predictive-search__loading-state' -%}
    </div>

    <span class="predictive-search-status visually-hidden" role="status" aria-hidden="true"></span>
  {%- endif -%}
{%- if settings.predictive_search_enabled -%}
  </predictive-search>
{%- else -%}
  </search-form>
{%- endif -%}
